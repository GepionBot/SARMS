const getAthletePerformance = async (req, res) => {
  try {
    const Performance = require("../model/performance");
    const page = parseInt(req.query.page) || 1;
    const limit = parseInt(req.query.limit) || 10;
    const skip = (page - 1) * limit;

    const performances = await Performance.find({ athleteId: req.params.id })
      .populate("eventId", "title type startTime")
      .populate("teamId", "name sport")
      .skip(skip)
      .limit(limit)
      .sort({ createdAt: -1 });

    const total = await Performance.countDocuments({ athleteId: req.params.id });

    res.json({
      performances,
      page,
      pages: Math.ceil(total / limit),
      total,
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

const createPerformance = async (req, res) => {
  try {
    const Performance = require("../model/performance");
    const { athleteId, eventId, teamId, statistics, notes } = req.body;

    const performance = await Performance.create({
      athleteId,
      userId: req.user._id,
      eventId,
      teamId,
      statistics: {
        ...statistics,
        customMetrics: statistics.customMetrics || {}
      },
      notes,
      recordedBy: req.user._id
    });

    await performance.populate("eventId", "title type startTime");
    await performance.populate("teamId", "name sport");

    res.status(201).json(performance);
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

const updatePerformance = async (req, res) => {
  try {
    const Performance = require("../model/performance");
    const { statistics, notes } = req.body;

    const performance = await Performance.findById(req.params.performanceId);
    if (!performance) {
      return res.status(404).json({ message: "Performance record not found" });
    }

    if (statistics) {
      performance.statistics = {
        ...performance.statistics,
        ...statistics,
        customMetrics: statistics.customMetrics || performance.statistics?.customMetrics || {}
      };
    }
    if (notes !== undefined) {
      performance.notes = notes;
    }

    await performance.save();
    await performance.populate("eventId", "title type startTime");
    await performance.populate("teamId", "name sport");

    res.json(performance);
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

const deletePerformance = async (req, res) => {
  try {
    const Performance = require("../model/performance");
    
    const performance = await Performance.findById(req.params.performanceId);
    if (!performance) {
      return res.status(404).json({ message: "Performance record not found" });
    }

    await Performance.deleteOne({ _id: req.params.performanceId });
    res.json({ message: "Performance record deleted" });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

module.exports = {
  getAthletes,
  getAthleteById,
  getAthleteByUserId,
  createAthlete,
  updateAthlete,
  getAthleteAcademic,
  getAthletePhysical,
  getAthleteMedical,
  getAthletePerformance,
  createPerformance,
  updatePerformance,
  deletePerformance,
};
