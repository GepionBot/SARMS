const AthleteProfile = require("../model/athleteProfile");
const User = require("../model/users");

const getAthletes = async (req, res) => {
  try {
    // Athletes can only see their own profile
    if (req.user.role === 'athlete') {
      const athlete = await AthleteProfile.findOne({ userId: req.user._id })
        .populate("userId", "firstName lastName email avatar phone");
      if (!athlete) {
        return res.json({ athletes: [], page: 1, pages: 1, total: 0 });
      }
      return res.json({
        athletes: [athlete],
        page: 1,
        pages: 1,
        total: 1
      });
    }

    const page = parseInt(req.query.page) || 1;
    const limit = parseInt(req.query.limit) || 10;
    const skip = (page - 1) * limit;

    const { sport, teamId, search } = req.query;

    const query = {};
    if (sport) query["sport.primary"] = sport;
    if (teamId) query["sport.teamId"] = teamId;
    if (search) {
      query.$or = [
        { "academic.studentId": { $regex: search, $options: "i" } },
      ];
    }

    // Filter by coach's assigned sports
    if (req.user.role === 'coach' && req.user.sports && req.user.sports.length > 0) {
      query["sport.primary"] = { $in: req.user.sports };
    }

    const athletes = await AthleteProfile.find(query)
      .populate("userId", "firstName lastName email avatar phone")
      .skip(skip)
      .limit(limit)
      .sort({ createdAt: -1 });

    const total = await AthleteProfile.countDocuments(query);

    res.json({
      athletes,
      page,
      pages: Math.ceil(total / limit),
      total,
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

const getAthleteById = async (req, res) => {
  try {
    const athlete = await AthleteProfile.findById(req.params.id)
      .populate("userId", "firstName lastName email avatar phone");
    
    if (!athlete) {
      return res.status(404).json({ message: "Athlete not found" });
    }

    // Athletes can only view their own profile
    if (req.user.role === 'athlete') {
      const userAthlete = await AthleteProfile.findOne({ userId: req.user._id });
      if (!userAthlete || userAthlete._id.toString() !== req.params.id) {
        return res.status(403).json({ message: "Not authorized" });
      }
    }

    res.json(athlete);
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

const getAthleteByUserId = async (req, res) => {
  try {
    const athlete = await AthleteProfile.findOne({ userId: req.params.userId })
      .populate("userId", "firstName lastName email avatar phone");
    
    if (!athlete) {
      return res.status(200).json(null);
    }
    res.json(athlete);
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

const createAthlete = async (req, res) => {
  try {
    let userId;
    
    // If athlete is creating their own profile
    if (req.user.role === 'athlete') {
      userId = req.user._id;
      
      // Check if profile already exists
      const existingProfile = await AthleteProfile.findOne({ userId });
      if (existingProfile) {
        return res.status(400).json({ message: "Athlete profile already exists for this user" });
      }
    } else {
      // Admin/coach creating for another user
      const { userId: profileUserId } = req.body;
      if (!profileUserId) {
        return res.status(400).json({ message: "User ID is required" });
      }
      userId = profileUserId;

      const existingProfile = await AthleteProfile.findOne({ userId });
      if (existingProfile) {
        return res.status(400).json({ message: "Athlete profile already exists" });
      }
    }

    const { userId: _, ...profileData } = req.body;
    const athlete = await AthleteProfile.create({ userId, ...profileData });
    await athlete.populate("userId", "firstName lastName email avatar");

    res.status(201).json(athlete);
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error", error: error.message });
  }
};

const updateAthlete = async (req, res) => {
  try {
    const athlete = await AthleteProfile.findById(req.params.id);
    if (!athlete) {
      return res.status(404).json({ message: "Athlete not found" });
    }

    // Check authorization: athletes can only update their own profile
    if (req.user.role === 'athlete') {
      const userAthlete = await AthleteProfile.findOne({ userId: req.user._id });
      if (!userAthlete || userAthlete._id.toString() !== req.params.id) {
        return res.status(403).json({ message: "Not authorized to update this profile" });
      }
    }

    const allowedUpdates = [
      "dateOfBirth", "gender", "address", "emergencyContact",
      "academic", "physical", "medical", "sport"
    ];

    allowedUpdates.forEach(field => {
      if (req.body[field] !== undefined) {
        athlete[field] = req.body[field];
      }
    });

    await athlete.save();
    res.json(athlete);
  } catch (error) {
    console.error(error);
    res.status(500).json({ message: "Server error" });
  }
};

